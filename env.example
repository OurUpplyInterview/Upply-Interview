# ─────────────────────────────────────────────────────────
#  Upply AI Interview System — environment variables
#  Copy this file to .env and fill in the real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────

# Groq API key  (https://console.groq.com → API Keys)
GROQ_API_KEY=your_groq_api_key_here

# Upply backend base URL (no trailing slash)
UPPLY_BASE=https://api.upply.tech/api/v1

# Public URL where THIS server is reachable by candidates
# Must match the port uvicorn listens on
APP_URL=http://localhost:8001
INTERVIEW_BASE_URL=http://localhost:8001

# SQLite database file path (relative to project root)
DB_PATH=interview.db

# Default number of questions when none supplied by recruiter
DEFAULT_NUM_QUESTIONS=5

# SMTP — used for sending interview invitation emails
# For Gmail: enable "App Passwords" and use the 16-char app password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_16_char_app_password

# From-address shown in invitation emails
EMAIL_FROM=noreply@upply.tech
